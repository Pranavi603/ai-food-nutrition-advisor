margin:0;
font-family:Poppins;
background:radial-gradient(circle at center,#1f2937,#0f172a);
color:white;
}

/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:25px 80px;
}

.navbar nav{
display:flex;
gap:30px;
align-items:center;
}

.navbar a{
color:white;
text-decoration:none;
font-size:16px;
}

.signup{
border:1px solid white;
padding:8px 18px;
border-radius:25px;
}

/* HERO */

.hero{
display:flex;
justify-content:space-between;
align-items:center;
padding:120px 80px;
gap:80px;
}

/* LEFT SIDE */

.hero-left{
flex:1;
max-width:550px;
}

.hero-left h1{
font-size:60px;
line-height:1.1;
margin-bottom:20px;
}

.hero-left p{
font-size:18px;
color:#cbd5e1;
}

.cta{
margin-top:30px;
background:#22c55e;
border:none;
padding:16px 32px;
border-radius:30px;
color:white;
font-size:18px;
cursor:pointer;
}

/* RIGHT SIDE */

.hero-right{
flex:1;
display:flex;
flex-direction:column;
align-items:center;
gap:20px;
}

/* IMAGE CARDS */

.card{
background:white;
padding:15px;
border-radius:20px;
width:260px;
box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

.card img{
width:100%;
border-radius:15px;
}

.phone{
width:260px;
}

.features{
display:flex;
justify-content:center;
gap:40px;
padding:100px 80px;
}

.feature-card{
background:#111827;
padding:20px;
border-radius:20px;
width:280px;
text-align:center;
box-shadow:0 15px 30px rgba(0,0,0,0.3);
}

.feature-card img{
width:100%;
border-radius:15px;
}

.feature-card h3{
margin-top:15px;
}

.feature-card p{
color:#cbd5e1;
font-size:14px;
}

/* floating animation */

@keyframes float{
0%{transform:translateY(0px);}
50%{transform:translateY(-15px);}
100%{transform:translateY(0px);}
}

.running{
animation:float 6s ease-in-out infinite;
}

.chart{
animation:float 5s ease-in-out infinite;
}

.phone{
animation:float 7s ease-in-out infinite;
