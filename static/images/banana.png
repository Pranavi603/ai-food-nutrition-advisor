px</span><span> </span><span class="ͼy">solid</span><span> </span><span class="ͼy">white</span><span>;</span><br><span>padding:</span><span class="ͼy">8</span><span class="ͼv">px</span><span> </span><span class="ͼy">18</span><span class="ͼv">px</span><span>;</span><br><span>border-radius:</span><span class="ͼy">25</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* HERO */</span><br><br><span>.</span><span class="ͼ10">hero</span><span>{</span><br><span>display:</span><span class="ͼy">flex</span><span>;</span><br><span>justify-content:</span><span class="ͼy">space-between</span><span>;</span><br><span>align-items:</span><span class="ͼy">center</span><span>;</span><br><span>padding:</span><span class="ͼy">120</span><span class="ͼv">px</span><span> </span><span class="ͼy">80</span><span class="ͼv">px</span><span>;</span><br><span>gap:</span><span class="ͼy">80</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* LEFT SIDE */</span><br><br><span>.</span><span class="ͼ10">hero-left</span><span>{</span><br><span>flex:</span><span class="ͼy">1</span><span>;</span><br><span>max-width:</span><span class="ͼy">550</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">hero-left</span><span> </span><span class="ͼ13">h1</span><span>{</span><br><span>font-size:</span><span class="ͼy">60</span><span class="ͼv">px</span><span>;</span><br><span>line-height:</span><span class="ͼy">1.1</span><span>;</span><br><span>margin-bottom:</span><span class="ͼy">20</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">hero-left</span><span> </span><span class="ͼ13">p</span><span>{</span><br><span>font-size:</span><span class="ͼy">18</span><span class="ͼv">px</span><span>;</span><br><span>color:#cbd5e1;</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">cta</span><span>{</span><br><span>margin-top:</span><span class="ͼy">30</span><span class="ͼv">px</span><span>;</span><br><span>background:#22c55e;</span><br><span>border:</span><span class="ͼy">none</span><span>;</span><br><span>padding:</span><span class="ͼy">16</span><span class="ͼv">px</span><span> </span><span class="ͼy">32</span><span class="ͼv">px</span><span>;</span><br><span>border-radius:</span><span class="ͼy">30</span><span class="ͼv">px</span><span>;</span><br><span>color:</span><span class="ͼy">white</span><span>;</span><br><span>font-size:</span><span class="ͼy">18</span><span class="ͼv">px</span><span>;</span><br><span>cursor:</span><span class="ͼy">pointer</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* RIGHT SIDE */</span><br><br><span>.</span><span class="ͼ10">hero-right</span><span>{</span><br><span>flex:</span><span class="ͼy">1</span><span>;</span><br><span>display:</span><span class="ͼy">flex</span><span>;</span><br><span>flex-direction:</span><span class="ͼy">column</span><span>;</span><br><span>align-items:</span><span class="ͼy">center</span><span>;</span><br><span>gap:</span><span class="ͼy">20</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span class="ͼt">/* IMAGE CARDS */</span><br><br><span>.</span><span class="ͼ10">card</span><span>{</span><br><span>background:</span><span class="ͼy">white</span><span>;</span><br><span>padding:</span><span class="ͼy">15</span><span class="ͼv">px</span><span>;</span><br><span>border-radius:</span><span class="ͼy">20</span><span class="ͼv">px</span><span>;</span><br><span>width:</span><span class="ͼy">260</span><span class="ͼv">px</span><span>;</span><br><span>box-shadow:</span><span class="ͼy">0</span><span> </span><span class="ͼy">10</span><span class="ͼv">px</span><span> </span><span class="ͼy">30</span><span class="ͼv">px</span><span> </span><span class="ͼv">rgba</span><span>(</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0</span><span>,</span><span class="ͼy">0.2</span><span>);</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">card</span><span> </span><span class="ͼ13">img</span><span>{</span><br><span>width:</span><span class="ͼy">100</span><span class="ͼv">%</span><span>;</span><br><span>border-radius:</span><span class="ͼy">15</span><span class="ͼv">px</span><span>;</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">phone</span><span>{</span><br><span>width:</span><span class="ͼy">260</span><span class="ͼv">px</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
