.</span><span>className </span><span class="ͼv">=</span><span> </span><span class="ͼz">"food-icon"</span><span>;</span><br><br><span class="ͼ11">img</span><span class="ͼv">.</span><span>style</span><span class="ͼv">.</span><span>left </span><span class="ͼv">=</span><span> </span><span class="ͼ11">Math</span><span class="ͼv">.</span><span>random()</span><span class="ͼv">*</span><span class="ͼy">100</span><span> </span><span class="ͼv">+</span><span> </span><span class="ͼz">"vw"</span><span>;</span><br><span class="ͼ11">img</span><span class="ͼv">.</span><span>style</span><span class="ͼv">.</span><span>top </span><span class="ͼv">=</span><span> </span><span class="ͼ11">Math</span><span class="ͼv">.</span><span>random()</span><span class="ͼv">*</span><span class="ͼy">100</span><span> </span><span class="ͼv">+</span><span> </span><span class="ͼz">"vh"</span><span>;</span><br><br><span class="ͼ11">img</span><span class="ͼv">.</span><span>style</span><span class="ͼv">.</span><span>width </span><span class="ͼv">=</span><span> (</span><span class="ͼy">20</span><span> </span><span class="ͼv">+</span><span> </span><span class="ͼ11">Math</span><span class="ͼv">.</span><span>random()</span><span class="ͼv">*</span><span class="ͼy">30</span><span>) </span><span class="ͼv">+</span><span> </span><span class="ͼz">"px"</span><span>;</span><br><br><span class="ͼ11">container</span><span class="ͼv">.</span><span>appendChild(</span><span class="ͼ11">img</span><span>);</span><br><br><span>}</span><br><br><span class="ͼ13">&lt;/script&gt;</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div><div class="flex w-full justify-end px-3 mt-1" data-code-block-feedback-row="true"></div></div></div></pre>
