ia-label="Open image in full view"><img alt="Uploaded image" width="437" height="658" class="max-w-full aspect-square object-cover object-center h-32 w-32 rounded-ss-2xl rounded-es-2xl overflow-hidden rounded-lg w-fit transition-opacity duration-300 opacity-100" src="./banana_files/6f82a948-ceba-4615-a90b-cc2fd605ce71.png"></button></div></div><div class="h-32 w-32 rounded-se-2xl rounded-ee-sm overflow-hidden rounded-lg"><div class="bg-token-main-surface-secondary text-token-text-tertiary relative flex h-auto w-full max-w-lg items-center justify-center overflow-hidden aspect-square"><button type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="radix-_r_2jr_" data-state="closed" class="h-32 w-32 rounded-se-2xl rounded-ee-sm overflow-hidden rounded-lg" aria-label="Open image in full view"><img alt="Uploaded image" width="474" height="503" class="max-w-full aspect-square object-cover object-center h-32 w-32 rounded-se-2xl rounded-ee-sm overflow-hidden rounded-lg w-fit transition-opacity duration-300 opacity-100" src="./banana_files/9f0f6fa9-3ed6-407e-99e3-5419daeb4f32.png"></button></div></div></div></div><div class="user-message-bubble-color corner-superellipse/0.98 relative rounded-[22px] px-4 py-2.5 leading-6 rounded-se-lg max-w-(--user-chat-width,70%)"><div class="whitespace-pre-wrap">&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
&lt;title&gt;Smart AI Food Advisor&lt;/title&gt;

&lt;link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&amp;display=swap" rel="stylesheet"&gt;

&lt;style&gt;

body{
font-family:'Poppins', sans-serif;
background:linear-gradient(135deg,#74ebd5,#ACB6E5);
margin:0;
padding:0;
text-align:center;
}

h1{
margin-top:20px;
color:#2c3e50;
}

.card{
background:white;
width:60%;
margin:20px auto;
padding:20px;
border-radius:12px;
box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

input,select{
padding:8px;
border-radius:6px;
border:1px solid #ccc;
margin:5px;
}

button{
padding:10px 20px;
background:#27ae60;
color:white;
border:none;
border-radius:8px;
cursor:pointer;
font-weight:bold;
}

button:hover{
background:#219150;
}

&lt;/style&gt;

&lt;/head&gt;

&lt;body&gt;

&lt;h1&gt;Smart AI Food Advisor&lt;/h1&gt;

&lt;div class="card"&gt;

&lt;h2&gt;Your BMI Result&lt;/h2&gt;

&lt;p&gt;BMI: &lt;b&gt;{{bmi}}&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;Status:
&lt;span style="color:red;font-weight:bold;"&gt;
{{status}}
&lt;/span&gt;
&lt;/p&gt;

&lt;div class="suggestion-box"&gt;
&lt;h3&gt;Recommended Diet&lt;/h3&gt;
&lt;p&gt;{{ suggestion }}&lt;/p&gt;
&lt;/div&gt;

&lt;h3&gt;Daily Calorie Recommendation&lt;/h3&gt;

&lt;p&gt;Estimated Calories: &lt;b&gt;{{daily_calories}} kcal&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;{{calorie_advice}}&lt;/p&gt;

&lt;/div&gt;


&lt;div class="card"&gt;

&lt;h2&gt;Enter Food Intake&lt;/h2&gt;

&lt;form id="foodForm" action="/analyze" method="post"&gt;

&lt;input type="hidden" name="status" value="{{status}}"&gt;
&lt;input type="hidden" id="imagePath" name="image_path"&gt;

Food 1:
&lt;input type="text" name="food1"&gt;

Quantity:
&lt;input type="number" name="qty1" step="any"&gt;

&lt;select name="unit1"&gt;
&lt;option value="grams"&gt;grams&lt;/option&gt;
&lt;option value="count"&gt;count&lt;/option&gt;
&lt;/select&gt;

&lt;br&gt;&lt;br&gt;

Food 2:
&lt;input type="text" name="food2"&gt;

Quantity:
&lt;input type="number" name="qty2" step="any"&gt;

&lt;select name="unit2"&gt;
&lt;option value="grams"&gt;grams&lt;/option&gt;
&lt;option value="count"&gt;count&lt;/option&gt;
&lt;/select&gt;

&lt;br&gt;&lt;br&gt;

Food 3:
&lt;input type="text" name="food3"&gt;

Quantity:
&lt;input type="number" name="qty3" step="any"&gt;

&lt;select name="unit3"&gt;
&lt;option value="grams"&gt;grams&lt;/option&gt;
&lt;option value="count"&gt;count&lt;/option&gt;
&lt;/select&gt;

&lt;br&gt;&lt;br&gt;

&lt;button type="submit"&gt;Analyze Nutrition&lt;/button&gt;

&lt;/form&gt;

&lt;/div&gt;


&lt;div class="card"&gt;

&lt;h2&gt;AI Nutrition Assistant&lt;/h2&gt;

&lt;input type="text" id="userMessage" placeholder="Ask about nutrition"&gt;

&lt;button onclick="sendMessage()"&gt;Ask&lt;/button&gt;

&lt;button onclick="startVoice()"&gt;🎤&lt;/button&gt;

&lt;p id="botReply"&gt;&lt;/p&gt;

&lt;/div&gt;


&lt;div class="card"&gt;

&lt;h2&gt;Take Food Photo&lt;/h2&gt;

&lt;video id="camera" width="320" height="240" autoplay&gt;&lt;/video&gt;

&lt;br&gt;&lt;br&gt;

&lt;button onclick="startCamera()"&gt;Start Camera&lt;/button&gt;
&lt;button onclick="takePhoto()"&gt;Capture&lt;/button&gt;
&lt;button onclick="stopCamera()"&gt;Stop Camera&lt;/button&gt;

&lt;br&gt;&lt;br&gt;

&lt;canvas id="photoCanvas" width="320" height="240"&gt;&lt;/canvas&gt;

&lt;/div&gt;


&lt;div class="card"&gt;

&lt;h2&gt;Upload Food Image&lt;/h2&gt;

&lt;input type="file" id="foodImage" onchange="detectFood()"&gt;

&lt;br&gt;&lt;br&gt;

&lt;button onclick="detectFood()"&gt;Detect Food&lt;/button&gt;

&lt;p id="foodResult"&gt;&lt;/p&gt;

&lt;/div&gt;

&lt;script&gt;

/* AI CHATBOT */

async function sendMessage(){

let message = document.getElementById("userMessage").value;

let response = await fetch("/chatbot",{
method:"POST",
headers:{"Content-Type":"application/json"},
body: JSON.stringify({message:message})
});

let data = await response.json();

document.getElementById("botReply").innerText = data.reply;

}

/* VOICE INPUT */

function startVoice(){

const recognition = new webkitSpeechRecognition();

recognition.onresult = function(event){

let text = event.results[0][0].transcript;

document.getElementById("userMessage").value = text;

};

recognition.start();

}

/* CAMERA */

let video = document.getElementById("camera");
let canvas = document.getElementById("photoCanvas");
let context = canvas.getContext("2d");
let stream = null;

async function startCamera(){

stream = await navigator.mediaDevices.getUserMedia({video:true});
video.srcObject = stream;

}

function takePhoto(){

context.drawImage(video,0,0,320,240);

document.getElementsByName("food1")[0].value = "apple";
document.getElementsByName("qty1")[0].value = 100;

document.getElementById("foodForm").submit();

}

/* IMAGE UPLOAD */

async function detectFood(){

let file = document.getElementById("foodImage").files[0];

if(!file){
alert("Please select an image");
return;
}

let formData = new FormData();
formData.append("file", file);

let response = await fetch("/predict-food",{
method:"POST",
body: formData
});

let data = await response.json();

document.getElementById("foodResult").innerText =
"Detected Food: " + data.food;

document.getElementsByName("food1")[0].value = data.food;
document.getElementsByName("qty1")[0].value = 100;

document.getElementById("imagePath").value = data.image;

document.getElementById("foodForm").submit();

}

&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;</div></div></div></div><div class="text-token-text-secondary my-2 me-4 flex flex-row justify-end gap-1 text-xs"></div></div><div class="z-0 flex justify-end"><div class="touch:-me-2 touch:-ms-3.5 -ms-2.5 -me-1 flex flex-wrap items-center gap-y-4 p-1 select-none focus-within:transition-none hover:transition-none touch:pointer-events-auto touch:opacity-100 duration-300 group-hover/turn-messages:delay-300 pointer-events-none opacity-0 motion-safe:transition-opacity group-hover/turn-messages:pointer-events-auto group-hover/turn-messages:opacity-100 group-focus-within/turn-messages:pointer-events-auto group-focus-within/turn-messages:opacity-100 has-data-[state=open]:pointer-events-auto has-data-[state=open]:opacity-100" style="mask-position: 0% 0%;"><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Copy" aria-pressed="false" data-testid="copy-turn-action-button" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-fk4oovux.svg#ce3544" fill="currentColor"></use></svg></span></button><button class="text-token-text-secondary hover:bg-token-bg-secondary rounded-lg" aria-label="Edit message" aria-pressed="false" data-state="closed"><span class="flex items-center justify-center touch:w-10 h-8 w-8"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-fk4oovux.svg#6d87e1" fill="currentColor"></use></svg></span></button></div></div></div></div><span class="sr-only"><br></span></article><article class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-[calc(var(--hea