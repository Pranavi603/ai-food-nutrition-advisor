/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:25px 80px;
}

.navbar nav{
display:flex;
gap:25px;
}

.navbar a{
color:white;
text-decoration:none;
}

.signup{
border:1px solid white;
padding:8px 18px;
border-radius:25px;
}

/* HERO */

.hero{
display:flex;
justify-content:space-between;
align-items:center;
padding:100px 80px;
gap:50px;
}

/* LEFT SIDE */

.hero-left{
flex:1;
max-width:550px;
}

.hero-left h1{
font-size:60px;
line-height:1.1;
}

.hero-left p{
margin-top:20px;
color:#cbd5e1;
}

.cta{
margin-top:30px;
background:#22c55e;
border:none;
padding:16px 30px;
border-radius:30px;
color:white;
font-size:18px;
cursor:pointer;
}

/* RIGHT SIDE */

.hero-right{
flex:1;
position:relative;
}

/* phone */

.phone{
width:240px;
position:absolute;
right:0;
top:50px;
}

