 id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼv">#</span><span class="ͼ13">food-background</span><span>{</span><br><span>position:</span><span class="ͼy">fixed</span><span>;</span><br><span>top:</span><span class="ͼy">0</span><span>;</span><br><span>left:</span><span class="ͼy">0</span><span>;</span><br><span>width:</span><span class="ͼy">100</span><span class="ͼv">%</span><span>;</span><br><span>height:</span><span class="ͼy">100</span><span class="ͼv">%</span><span>;</span><br><span>z-index:</span><span class="ͼy">-1</span><span>;</span><br><span>overflow:</span><span class="ͼy">hidden</span><span>;</span><br><span>background:#0f172a;</span><br><span>}</span><br><br><span>.</span><span class="ͼ10">food-icon</span><span>{</span><br><span>position:</span><span class="ͼy">absolute</span><span>;</span><br><span>width:</span><span class="ͼy">40</span><span class="ͼv">px</span><span>;</span><br><span>opacity:</span><span class="ͼy">0.15</span><span>;</span><br><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
