       </span><span class="ͼv">return</span><span> </span><span class="ͼ11">RedirectResponse</span><span>(</span><span class="ͼ11">url</span><span class="ͼv">=</span><span class="ͼz">"/details"</span><span>, </span><span class="ͼ11">status_code</span><span class="ͼv">=</span><span class="ͼy">303</span><span>)</span><br><br><span>    </span><span class="ͼv">return</span><span> </span><span class="ͼ11">templates</span><span class="ͼv">.</span><span>TemplateResponse(</span><br><span>        </span><span class="ͼz">"login.html"</span><span>,</span><br><span>        {</span><span class="ͼz">"request"</span><span>: </span><span class="ͼ11">request</span><span>, </span><span class="ͼz">"error"</span><span>: </span><span class="ͼz">"Invalid username or password"</span><span>}</span><br><span>    )</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
