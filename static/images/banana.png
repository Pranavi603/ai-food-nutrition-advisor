t"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">class</span><span class="ͼv">=</span><span class="ͼz">"card yellow"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;img</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"/static/images/running.jpg"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;p&gt;</span><span>Develop healthy habits</span><span class="ͼ13">&lt;/p&gt;</span><br><span class="ͼ13">&lt;/div&gt;</span><br><br><span class="ͼ13">&lt;img</span><span> </span><span class="ͼ12">class</span><span class="ͼv">=</span><span class="ͼz">"card chart"</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"/static/images/chart.png"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;img</span><span> </span><span class="ͼ12">class</span><span class="ͼv">=</span><span class="ͼz">"phone"</span><span> </span><span class="ͼ12">src</span><span class="ͼv">=</span><span class="ͼz">"/static/images/phone-ui.png"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;/div&gt;</span><br><br><span class="ͼ13">&lt;/section&gt;</span><br><br><span class="ͼ13">&lt;/body&gt;</span><br><span class="ͼ13">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div><div class="flex w-full justify-end px-3 mt-1" data-code-block-feedback-row="true"></div></div></div></pre>
