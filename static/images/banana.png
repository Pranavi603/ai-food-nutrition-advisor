"cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼu">&lt;!DOCTYPE html&gt;</span><br><span class="ͼ13">&lt;html&gt;</span><br><span class="ͼ13">&lt;head&gt;</span><br><span class="ͼ13">&lt;meta</span><span> </span><span class="ͼ12">charset</span><span class="ͼv">=</span><span class="ͼz">"UTF-8"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;title&gt;</span><span>Login - Smart AI Food Advisor</span><span class="ͼ13">&lt;/title&gt;</span><br><span class="ͼ13">&lt;link</span><span> </span><span class="ͼ12">rel</span><span class="ͼv">=</span><span class="ͼz">"stylesheet"</span><span> </span><span class="ͼ12">href</span><span class="ͼv">=</span><span class="ͼz">"/static/css/login.css"</span><span class="ͼ13">&gt;</span><br><span class="ͼ13">&lt;/head&gt;</span><br><br><span class="ͼ13">&lt;body&gt;</span><br><br><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">class</span><span class="ͼv">=</span><span class="ͼz">"login-container"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;div</span><span> </span><span class="ͼ12">class</span><span class="ͼv">=</span><span class="ͼz">"login-box"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;h1&gt;</span><span>Smart AI Food Advisor</span><span class="ͼ13">&lt;/h1&gt;</span><br><br><span class="ͼ13">&lt;form</span><span> </span><span class="ͼ12">action</span><span class="ͼv">=</span><span class="ͼz">"/login"</span><span> </span><span class="ͼ12">method</span><span class="ͼv">=</span><span class="ͼz">"post"</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;input</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"text"</span><span> </span><span class="ͼ12">placeholder</span><span class="ͼv">=</span><span class="ͼz">"Username"</span><span> </span><span class="ͼ12">required</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;input</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"password"</span><span> </span><span class="ͼ12">placeholder</span><span class="ͼv">=</span><span class="ͼz">"Password"</span><span> </span><span class="ͼ12">required</span><span class="ͼ13">&gt;</span><br><br><span class="ͼ13">&lt;button</span><span> </span><span class="ͼ12">type</span><span class="ͼv">=</span><span class="ͼz">"submit"</span><span class="ͼ13">&gt;</span><span>Login</span><span class="ͼ13">&lt;/button&gt;</span><br><br><span class="ͼ13">&lt;/form&gt;</span><br><br><span class="ͼ13">&lt;/div&gt;</span><br><br><span class="ͼ13">&lt;/div&gt;</span><br><br><span class="ͼ13">&lt;/body&gt;</span><br><span class="ͼ13">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div><div class="flex w-full justify-end px-3 mt-1" data-code-block-feedback-row="true"></div></div></div></pre>
