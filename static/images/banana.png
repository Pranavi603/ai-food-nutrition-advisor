iv id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>uvicorn main:app </span><span class="ͼ12">--reload</span><span> </span><span class="ͼ12">--port</span><span> </span><span class="ͼy">9000</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<p data-start="1521" data-end="1532">Then go to:</p>
