r><span>    </span><span class="ͼv">if</span><span> </span><span class="ͼ11">username</span><span> </span><span class="ͼv">==</span><span> </span><span class="ͼz">"admin"</span><span> </span><span class="ͼv">and</span><span> </span><span class="ͼ11">password</span><span> </span><span class="ͼv">==</span><span> </span><span class="ͼz">"123"</span><span>:</span><br><span>        </span><span class="ͼv">return</span><span> </span><span class="ͼ11">RedirectResponse</span><span>(</span><span class="ͼ11">url</span><span class="ͼv">=</span><span class="ͼz">"/details"</span><span>, </span><span class="ͼ11">status_code</span><span class="ͼv">=</span><span class="ͼy">303</span><span>)</span><br><br><span>    </span><span class="ͼv">return</span><span> {</span><span class="ͼz">"message"</span><span>: </span><span class="ͼz">"Invalid login"</span><span>}</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="934" data-end="937">
<h1 data-start="939" data-end="969">✅ Also Fix Your <code data-start="957" data-end="969">login.html</code></h1>
<p data-start="971" data-end="1049">Your inputs must have <strong data-start="993" data-end="1012">name attributes</strong>, otherwise FastAPI cannot read them.</p>
