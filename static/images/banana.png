<p data-start="683" data-end="693">Important:</p>
<div class="TyagGW_tableContainer"><div tabindex="-1" class="group TyagGW_tableWrapper flex flex-col-reverse w-fit"><table data-start="695" data-end="796" class="w-fit min-w-(--thread-content-width)"><thead data-start="695" data-end="719"><tr data-start="695" data-end="719"><th data-start="695" data-end="707" data-col-size="sm" class="">Attribute</th><th data-start="707" data-end="719" data-col-size="sm" class="">Required</th></tr></thead><tbody data-start="745" data-end="796"><tr data-start="745" data-end="770"><td data-start="745" data-end="765" data-col-size="sm"><code data-start="747" data-end="764">name="username"</code></td><td data-start="765" data-end="770" data-col-size="sm">✅</td></tr><tr data-start="771" data-end="796"><td data-start="771" data-end="791" data-col-size="sm"><code data-start="773" data-end="790">name="password"</code></td><td data-start="791" data-end="796" data-col-size="sm">✅</td></tr></tbody></table><div class="sticky h-0 select-none end-(--thread-content-margin) self-end"><div class="absolute end-0 flex items-end" style="height: 32.7969px;"><span class="" data-state="closed"><button aria-label="Copy table" class="hover:bg-token-bg-tertiary text-token-text-secondary my-1 rounded-sm p-1 transition-opacity group-[:not(:hover):not(:focus-within)]:pointer-events-none group-[:not(:hover):not(:focus-within)]:opacity-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon"><use href="/cdn/assets/sprites-core-fk4oovux.svg#ce3544" fill="currentColor"></use></svg></button></span></div></div></div></div>
<p data-start="798" data-end="844">FastAPI reads <strong data-start="812" data-end="843">form data using these names</strong>.</p>
<hr data-start="846" data-end="849">
