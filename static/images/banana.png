n> </span><span class="ͼ11">bmi</span><span> </span><span class="ͼv">&lt;</span><span> </span><span class="ͼy">18.5</span><span>:</span><br><span>        </span><span class="ͼ11">status</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Underweight"</span><br><span>        </span><span class="ͼ11">status_color</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"blue"</span><br><span>        </span><span class="ͼ11">suggestion</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Eat calorie rich foods like rice, banana, milk and eggs."</span><br><br><span>    </span><span class="ͼv">elif</span><span> </span><span class="ͼ11">bmi</span><span> </span><span class="ͼv">&lt;</span><span> </span><span class="ͼy">25</span><span>:</span><br><span>        </span><span class="ͼ11">status</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Normal weight"</span><br><span>        </span><span class="ͼ11">status_color</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"green"</span><br><span>        </span><span class="ͼ11">suggestion</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Maintain a balanced diet with fruits, vegetables and protein."</span><br><br><span>    </span><span class="ͼv">elif</span><span> </span><span class="ͼ11">bmi</span><span> </span><span class="ͼv">&lt;</span><span> </span><span class="ͼy">30</span><span>:</span><br><span>        </span><span class="ͼ11">status</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Overweight"</span><br><span>        </span><span class="ͼ11">status_color</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"orange"</span><br><span>        </span><span class="ͼ11">suggestion</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Reduce fried foods and sugar. Eat more vegetables and fruits."</span><br><br><span>    </span><span class="ͼv">else</span><span>:</span><br><span>        </span><span class="ͼ11">status</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Obese"</span><br><span>        </span><span class="ͼ11">status_color</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"red"</span><br><span>        </span><span class="ͼ11">suggestion</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Avoid high calorie foods and increase physical activity."</span><br><br><span>    </span><span class="ͼv">return</span><span> </span><span class="ͼ11">templates</span><span class="ͼv">.</span><span>TemplateResponse(</span><br><span>        </span><span class="ͼz">"food.html"</span><span>,</span><br><span>        {</span><br><span>            </span><span class="ͼz">"request"</span><span>: </span><span class="ͼ11">request</span><span>,</span><br><span>            </span><span class="ͼz">"bmi"</span><span>: </span><span class="ͼ11">round</span><span>(</span><span class="ͼ11">bmi</span><span>,</span><span class="ͼy">2</span><span>),</span><br><span>            </span><span class="ͼz">"status"</span><span>: </span><span class="ͼ11">status</span><span>,</span><br><span>            </span><span class="ͼz">"status_color"</span><span>: </span><span class="ͼ11">status_color</span><span>,</span><br><span>            </span><span class="ͼz">"suggestion"</span><span>: </span><span class="ͼ11">suggestion</span><br><span>        }</span><br><span>    )</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<hr data-start="1346" data-end="1349">
<h1 data-start="1351" data-end="1382">2️⃣ Display it in <code data-start="1371" data-end="1382">food.html</code></h1>
<p data-start="1384" data-end="1456">Open <strong data-start="1389" data-end="1402">food.html</strong> and add this where you want the suggestion to appear:</p>
